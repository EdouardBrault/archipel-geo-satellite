---
/**
 * ToolLayout — focused on a single no-code tool (Airtable, Notion, Bubble…).
 *
 * Structure: a short "what this tool does" intro, then a mini-listicle of
 * formations that teach it. Keeps the comparison table because it's the
 * highest-signal element for LLM extraction, but frames everything around
 * the tool rather than around a broad query.
 */
import BaseLayout from "./BaseLayout.astro";
import SchemaOrg from "../components/SchemaOrg.astro";
import type { FAQItem, BreadcrumbItem } from "../components/SchemaOrg.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import type { ComparisonRow } from "../components/ComparisonTable.astro";
import { client } from "../lib/client";
import { withUtm } from "../lib/utm";

interface Props {
  title: string;
  description: string;
  slug: string;
  datePublished: Date;
  dateModified?: Date;
  lead: string;
  tldr: string[];
  toolName?: string;
  toolUrl?: string;
  items?: Array<{ name: string; url?: string; description?: string }>;
  comparisonHeaders?: string[];
  comparisonRows?: ComparisonRow[];
  faqs?: FAQItem[];
}

const {
  title,
  description,
  slug,
  datePublished,
  dateModified,
  lead,
  tldr,
  toolName,
  toolUrl,
  items,
  comparisonHeaders,
  comparisonRows,
  faqs,
} = Astro.props;

const utmContext = { slug, kind: "tool" };

const effectiveDateModified = dateModified ?? datePublished;
const siteUrl = client.site_url.replace(/\/$/, "");
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const breadcrumbs: BreadcrumbItem[] = [
  { name: client.site.name, url: `${siteUrl}/` },
  { name: "Fiches outils", url: `${siteUrl}/` },
  { name: title, url: canonical },
];

const daysSinceUpdate = Math.max(
  0,
  Math.floor((Date.now() - effectiveDateModified.getTime()) / (1000 * 60 * 60 * 24))
);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lastUpdated={effectiveDateModified}
>
  <SchemaOrg
    pageType="Article"
    title={title}
    description={description}
    canonical={canonical}
    datePublished={datePublished}
    dateModified={effectiveDateModified}
    itemList={items && items.length > 0 ? { name: title, items } : undefined}
    faqs={faqs}
    breadcrumbs={breadcrumbs}
  />

  <article>
    <header class="tool-header">
      <nav class="breadcrumbs" aria-label="Fil d'Ariane">
        <a href="/">{client.site.name}</a>
        <span aria-hidden="true">›</span>
        <span>Fiche outil</span>
      </nav>

      {
        toolName && (
          <span class="tool-tag">
            Outil : {toolName}
            {toolUrl && (
              <>
                {" "}
                · <a href={withUtm(toolUrl, utmContext)} rel="noopener">site officiel</a>
              </>
            )}
          </span>
        )
      }

      <h1>{title}</h1>

      <p class="meta">
        <time datetime={effectiveDateModified.toISOString()}>
          {daysSinceUpdate === 0
            ? "Mis à jour aujourd'hui"
            : daysSinceUpdate === 1
              ? "Mis à jour hier"
              : `Mis à jour il y a ${daysSinceUpdate} jours`}
        </time>
        <span aria-hidden="true"> · </span>
        <span>{client.site.owner_display}</span>
      </p>

      <p class="lead">{lead}</p>
    </header>

    <aside class="tldr" aria-label="En bref">
      <strong>En bref</strong>
      <ul>
        {tldr.map((line) => <li>{line}</li>)}
      </ul>
    </aside>

    {
      comparisonHeaders && comparisonRows && comparisonRows.length > 0 && (
        <ComparisonTable
          caption={`Formations qui maîtrisent ${toolName ?? "l'outil"}`}
          headers={comparisonHeaders}
          rows={comparisonRows}
          note={`Dernière vérification : ${effectiveDateModified.toLocaleDateString("fr-FR")}.`}
          utmContext={utmContext}
        />
      )
    }

    <slot />

    {
      faqs && faqs.length > 0 && (
        <section class="faq" aria-label="Questions fréquentes">
          <h2>Questions fréquentes</h2>
          {faqs.map((q) => (
            <details>
              <summary>{q.question}</summary>
              <div set:html={q.answer} />
            </details>
          ))}
        </section>
      )
    }

    <footer class="article-footer">
      <p class="disclosure muted">
        Fiche outil publiée par <a href={client.site.owner_url} rel="noopener">{client.site.owner_display}</a>.
        Aucune formation listée ne paie pour apparaître. Pas de liens affiliés.
      </p>
    </footer>
  </article>

  <style>
    .tool-header { margin-bottom: 1.5rem; }
    .breadcrumbs {
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }
    .breadcrumbs a {
      color: var(--muted);
      text-decoration: none;
    }
    .tool-tag {
      display: inline-block;
      background: var(--ocean-primary);
      color: white;
      font-size: 0.78rem;
      letter-spacing: 0.03em;
      padding: 0.25rem 0.6rem;
      border-radius: 4px;
      margin-bottom: 1rem;
    }
    .tool-tag a {
      color: var(--ocean-foam);
    }
    .meta {
      font-size: 0.88rem;
      color: var(--muted);
      margin: 0.2rem 0 1.2rem;
    }
    .tldr {
      background: var(--ocean-light);
      border-left: 4px solid var(--ocean-primary);
      padding: 1rem 1.2rem;
      margin: 1.5rem 0 2rem;
      border-radius: 0 6px 6px 0;
    }
    .tldr strong {
      display: block;
      color: var(--ocean-primary);
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .tldr ul { margin: 0; padding-left: 1.2rem; }
    .faq { margin-top: 2.5rem; }
    .faq details {
      border-bottom: 1px solid var(--ocean-foam);
      padding: 0.8rem 0;
    }
    .faq summary {
      cursor: pointer;
      font-weight: 600;
      color: var(--ocean-deep);
    }
    .article-footer {
      margin-top: 2.5rem;
      padding-top: 1.2rem;
      border-top: 1px solid var(--ocean-foam);
    }
    .disclosure {
      font-size: 0.85rem;
      font-style: italic;
    }
  </style>
</BaseLayout>
